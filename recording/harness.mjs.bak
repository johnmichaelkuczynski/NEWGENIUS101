    await sleep(700);
    // AI model dropdown: open, show options, pick OpenAI
    await selectRadix(page.getByTestId('select-ai-model'), 'OpenAI').catch(async()=>{
      await click(page.getByTestId('select-ai-model'));
      await page.getByTestId('option-openai').click().catch(()=>{});
    });
    await sleep(700);
    // Intensity slider: Faithful -> Wild and back
    const slider = page.getByTestId('slider-intensity-level').getByRole('slider').first();
    await glideTo(slider);
    await slider.focus().catch(()=>{});
    for (let i=0;i<6;i++){ await page.keyboard.press('ArrowRight'); await sleep(350); }
    await sleep(700);
    for (let i=0;i<6;i++){ await page.keyboard.press('ArrowLeft'); await sleep(350); }
    await sleep(700);
    // Dialogue mode toggle
    await click(page.getByTestId('switch-dialogue-mode'));
    await sleep(800);
  });

  // ---------------- 9:30 NAV: My Chats + Diagnostics ----------------
  await segment('My Chats', async () => {
    await click(page.getByTestId('button-chat-history'));
    await sleep(2000);
    await scrollPage(300, 3);
