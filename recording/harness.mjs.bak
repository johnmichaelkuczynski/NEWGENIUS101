    await dismissOverlays();
    await sleep(800);
  });
  await segment('Diagnostics', async () => {
    await click(page.getByTestId('link-diagnostics'));
    await sleep(2500);
    await page.evaluate(CURSOR_SCRIPT).catch(()=>{});
    await waitVisible(page.getByTestId('heading-diagnostics'), 15000, 'diagnostics page');
    // run one diagnostic check to show the panel working
    const runBtn = page.locator('[data-testid^="button-run-"]').first();
    if (await runBtn.isVisible().catch(()=>false)) {
      await click(runBtn);
      await sleep(8000);
      await click(page.getByTestId('button-stop-diagnostics')).catch(()=>{});
    }
    await scrollPage(500, 5);
    await sleep(1500);
  });

  log('All segments complete. Finalizing video...');
  await sleep(1500);
  const video = page.video();
  await context.close();
  await browser.close();
  if (video) {
    const p = await video.path();
    const dest = path.join(OUT_DIR, 'genius101-promo.webm');
    fs.copyFileSync(p, dest);
    log('VIDEO SAVED:', dest, `(${(fs.statSync(dest).size/1e6).toFixed(1)} MB)`);
  } else {
    log('WARN: no video handle');
  }
  log('TOTAL RUNTIME:', ts());
  log('DONE_MARKER');
  if (process.env.HOLD) { log('HOLD: keeping process alive (remove workflow to stop)'); await new Promise(()=>{}); }
})().catch(e => {
  log('FATAL:', e.stack || e.message);
  if (process.env.HOLD) { log('HOLD after fatal'); return new Promise(()=>{}); }
  process.exit(1);
});
