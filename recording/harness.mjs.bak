    await typeInto(sec.getByTestId('input-word-length'), '800', 40);
    await sleep(400);
    await runPopupGenerator(sec.getByTestId('button-generate-interview'), 'interview', 360000);
  });

  // ---------------- 6:30 DEBATE CREATOR (Bergson vs James) ----------------
  await segment('Debate Creator (Bergson vs James)', async () => {
    const sec = page.locator('#debate-creator-section');
