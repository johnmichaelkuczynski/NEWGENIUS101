    await sleep(400);
    await runPopupGenerator(sec.getByTestId('button-generate-debate'), 'debate', 360000);
  });

  // ---------------- 7:30 QUOTE GENERATOR (author + upload) ----------------
  await segment('Quote Generator (site author)', async () => {
    const sec = page.locator('#quote-generator-section');
    await sec.scrollIntoViewIfNeeded();
    await sleep(800);
    await click(sec.getByTestId('select-author-quotes'));
    await sleep(500);
    const ci = page.getByPlaceholder('Search authors...');
    await ci.fill('Freud').catch(()=>{});
    await sleep(700);
    await page.getByRole('option', { name: 'Freud', exact: true }).first().click().catch(async()=>{
      await page.getByText('Freud', { exact: true }).first().click();
    });
    await sleep(600);
    await typeInto(sec.getByTestId('input-query-quotes'), 'free will', 12);
    await typeInto(sec.getByTestId('input-num-quotes'), '10', 60);
    await sleep(400);
    await click(sec.getByTestId('button-generate-quotes'));
    log('  generating quotes (JSON)...');
    await waitStable(sec.locator('.prose').first(), { stableMs: 6000, capMs: 120000, pollMs: 2500 }, 'quotes (author)');
    await scrollPage(500, 5);
    await sleep(800);
  });
  await segment('Quote Generator (file upload)', async () => {
    const sec = page.locator('#quote-generator-section');
    await sec.scrollIntoViewIfNeeded();
    await click(sec.getByTestId('tab-mode-upload'));
    await sleep(800);
    const fileInput = sec.locator('input[type="file"]').first();
    await fileInput.setInputFiles(path.join(__dirname, 'sample-upload.txt'));
    await sleep(1200);
    await click(sec.getByTestId('button-generate-quotes'));
    log('  extracting quotes from upload...');
    await waitStable(sec.locator('.prose').first(), { stableMs: 6000, capMs: 120000, pollMs: 2500 }, 'quotes (upload)');
    await sleep(900);
  });

  // ---------------- 8:15 COMPARE THINKERS ----------------
  await segment('Compare Thinkers (Freud vs Jung)', async () => {
    await page.evaluate(()=>window.scrollTo({top:0}));
    await sleep(800);
    await click(page.getByTestId('button-compare-thinkers'));
    await sleep(1200);
    await typeInto(page.getByTestId('input-search-figure1'), 'Freud', 50);
    await sleep(600);
    await click(page.getByTestId('select-figure1-freud'));
    await typeInto(page.getByTestId('input-search-figure2'), 'Jung', 50);
    await sleep(600);
    await click(page.getByTestId('select-figure2-jung'));
    await sleep(800);
    await typeInto(page.getByTestId('input-comparison-message'), 'the unconscious origin of decisions', 8);
    await sleep(400);
    await click(page.getByTestId('button-send-comparison'));
    log('  generating comparison...');
